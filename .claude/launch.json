{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "zalo-mini-app (dev)",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": [".claude/start-dev.sh"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "zalo-mini-app (production)",
      "runtimeExecutable": "/opt/homebrew/bin/npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
